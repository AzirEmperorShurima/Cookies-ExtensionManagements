{
    "manifest_version": 3,
    "author": "Justinan - DrakeDev",
    "name": "Privacy & Cookies Manager",
    "version": "1.5.0",
    "description": "Comprehensive Privacy & Cookie Manager: Manage cookies (view, copy, paste, delete), Privacy Player for isolated video viewing, secure Vault for sensitive links, Panic Button, and Multi-Account Containers support.",
    "permissions": [
        "cookies",
        "tabs",
        "storage",
        "management",
        "notifications",
        "privacy",
        "history",
        "sessions",
        "bookmarks",
        "readingList",
        "downloads",
        "scripting",
        "contextMenus",
        "webRequest",
        "webNavigation",
        "declarativeNetRequest",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "popup.html"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon16.png",
            "128": "icons/icon16.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon128.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": ["telegram_content.js", "template/TelegramAdaptiveEngine.js"],
            "matches": ["https://web.telegram.org/*", "https://webk.telegram.org/*", "https://webz.telegram.org/*"]
        }
    ],
    "content_scripts": [
        {
            "matches": ["https://web.telegram.org/*", "https://webk.telegram.org/*", "https://webz.telegram.org/*"],
            "js": ["telegram_content.js"],
            "run_at": "document_idle"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["videoDetector.js", "iframe_content_script.js"],
            "all_frames": true,
            "run_at": "document_start",
            "match_about_blank": true
        }
    ],
    "commands": {
        "activate_panic": {
            "suggested_key": {
                "default": "Alt+Shift+X",
                "windows": "Alt+Shift+X",
                "mac": "Alt+Shift+X"
            },
            "description": "Kích hoạt chế độ Panic ngay lập tức"
        }
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_1",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}